# examples/ai-agent — set ONE provider key, then:
#   node --env-file=.env examples/ai-agent/generate.mjs "your goal"
# (never commit the real .env — it is gitignored)

# GLM (z.ai, OpenAI-compatible)
GLM_API_KEY=
# GLM_MODEL=glm-4.6

# Gemini (GEMINI_API_KEY or GOOGLE_API_KEY both work)
GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5

# Force a provider regardless of which keys are set: glm | gemini | anthropic
# REFLOW_AI_PROVIDER=gemini
